



{
  "compilerOptions": {
   "module": "ESNext", 
   "moduleResolution": "bundler",
   "target": "ES2023",                               
    "rootDir": "./src",
    "outDir": "./dist",  
    // "moduleResolution": "node10", 
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
    //  "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}